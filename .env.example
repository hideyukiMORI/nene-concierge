APP_ENV=local
APP_DEBUG=false
APP_NAME="NeNe Concierge"
NENE2_MACHINE_API_KEY=
NENE2_LOCAL_JWT_SECRET=
PROBLEM_DETAILS_BASE_URL=https://nene-concierge.dev/problems/

# --- Multi-tenancy ---
# TENANT_RESOLUTION: single | subdomain | path
# single  = ORG_SLUG env var (Tier A / single-org Tier B)
# subdomain = org1.example.com → slug "org1"
# path    = /org1/api/v1/... → slug "org1"
TENANT_RESOLUTION=single
ORG_SLUG=

# --- Database (host / PHPUnit default: SQLite) ---
DATABASE_URL=
DB_ENV=local
DB_ADAPTER=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=var/nene_concierge.sqlite
DB_USER=nene_concierge
DB_PASSWORD=
DB_CHARSET=utf8mb4

# --- Docker Compose overrides (copy to .env and uncomment for local stack) ---
# DB_ADAPTER=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=nene_concierge
# DB_USER=nene_concierge
# DB_PASSWORD=nene_concierge
# MYSQL_ROOT_PASSWORD=nene_concierge_root
#
# NeNe Concierge 固定ポート (87xx/3790 — NeNe エコシステム内でユニーク)
# 変更する場合は docs/workflow.md のポートマップも更新すること
NENE_CONCIERGE_PORT=8790
NENE_CONCIERGE_MYSQL_PORT=3790
NENE_CONCIERGE_PHPMYADMIN_PORT=8791
