{
  "name": "nene-concierge-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NeNe Concierge embed widget and frontend assets",
  "scripts": {
    "build": "node esbuild.mjs",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:ratchet": "node scripts/eslint-suppressions-ratchet.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run type-check && npm run lint && npm run lint:ratchet && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hideyukimori/nene2-standards": "^1.1.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.28.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@hideyukimori/nene2-client": "^1.1.0",
    "@xyflow/react": "^12.10.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "uuid": "^14.0.0"
  }
}
